# Network: 1 or true = Coston2 testnet, 0 or false = Flare mainnet
USE_TESTNET=1

# EntityManager contract address (testnet or mainnet)
ENTITY_MANAGER_ADDRESS=0x...

# Ledger paths (optional; only Identity and Delegation use device). Defaults shown.
LEDGER_IDENTITY_PATH=44'/60'/0'/0/0
LEDGER_DELEGATION_PATH=44'/60'/0'/0/1

# Hot wallet addresses (required; must match the private keys below).
SUBMIT_ADDRESS=0x...
SUBMIT_SIGNATURES_ADDRESS=0x...
SIGNING_POLICY_ADDRESS=0x...

# Hot wallet private keys (required for Step B: Submit, SubmitSignatures, SigningPolicy confirm).
# Addresses must match SUBMIT_ADDRESS, SUBMIT_SIGNATURES_ADDRESS, SIGNING_POLICY_ADDRESS above.
SUBMIT_PRIVATE_KEY=0x...
SUBMIT_SIGNATURES_PRIVATE_KEY=0x...
SIGNING_POLICY_PRIVATE_KEY=0x...

# registerPublicKey.js: Identity signs on Ledger.
PUBLIC_KEY_X=
PUBLIC_KEY_Y=
SORTITION_SIGNATURE=

# registerNodeId.js: Identity signs on Ledger.
NODE_ID=
CERTIFICATE_RAW=
VALIDATOR_SIGNATURE=